# Frosted-glass notifications - works well on top of swayfx blur.
# Lower alpha values (0xAA -> 0x99 -> 0x88) bleed more of the underlying
# blurred wallpaper / window through the notification card.

font=Noto Sans 12
markup=1
actions=1
history=1
max-history=20
icons=1
max-icon-size=48
icon-location=left

# Layout
layer=overlay
anchor=top-right
width=360
padding=14,18
margin=10,14
outer-margin=10
border-size=1
border-radius=16
default-timeout=5000

# Colors - Gruvbox Dark with intentional transparency
background-color=#1d202199
text-color=#ebdbb2
border-color=#fabd2fbb
progress-color=over #fabd2f55

# Mouse / touch interactions
on-button-left=dismiss
on-button-right=dismiss-all
on-button-middle=invoke-default-action

[urgency=low]
background-color=#1d202188
border-color=#83a598aa
text-color=#a89984
default-timeout=4000

[urgency=normal]
background-color=#1d202199
border-color=#fabd2fbb

[urgency=high]
background-color=#cc241daa
border-color=#fb4934ee
text-color=#fbf1c7
default-timeout=0

[app-name="Meshtastic"]
border-color=#83a598cc
default-timeout=8000
